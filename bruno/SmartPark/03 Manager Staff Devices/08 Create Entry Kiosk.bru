meta {
  name: Create Entry Kiosk
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/manager/kiosks
  body: json
  auth: bearer
}

auth:bearer {
  token: {{managerToken}}
}
headers {
  Content-Type: application/json
}

body:json {
  {
    "parkingId": "{{parkingId}}",
    "name": "Main Entry Kiosk",
    "type": "ENTRY",
    "status": "ACTIVE"
  }
}
