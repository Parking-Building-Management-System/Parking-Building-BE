meta {
  name: Reset Staff Password
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/manager/staff/{{staffId}}/reset-password
  body: json
  auth: bearer
}

auth:bearer {
  token: {{managerToken}}
}
headers {
  Content-Type: application/json
}

body:json {
  {
    "newPassword": "ChangeMe123!"
  }
}
