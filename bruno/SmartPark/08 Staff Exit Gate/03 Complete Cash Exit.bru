meta {
  name: Complete Cash Exit
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/staff/parking-sessions/complete-exit
  body: json
  auth: bearer
}

auth:bearer {
  token: {{staffExitToken}}
}
headers {
  Content-Type: application/json
}

body:json {
  {
    "sessionId": "{{sessionId}}",
    "cardCode": "{{cardCode}}",
    "paymentMode": "CASH",
    "collectedAmount": 30000,
    "note": "Cash collected at exit"
  }
}
