meta {
  name: Update Pricing Rule Status
  type: http
  seq: 5
}

patch {
  url: {{baseUrl}}/manager/pricing/rules/{{pricingRuleId}}/status
  body: json
  auth: bearer
}

auth:bearer {
  token: {{managerToken}}
}
headers {
  Content-Type: application/json
}

body:json {
  {
    "status": "ACTIVE"
  }
}
