meta {
  name: Update Floor Map
  type: http
  seq: 23
}

patch {
  url: {{baseUrl}}/manager/floors/{{floorId}}/map
  body: json
  auth: bearer
}

auth:bearer {
  token: {{managerToken}}
}
headers {
  Content-Type: application/json
}

body:json {
  {
    "mapImageUrl": "{{objectKey}}"
  }
}

docs {
  Map upload flow: presign upload, PUT the file to the returned uploadUrl outside Bruno if needed, then set `objectKey` from the presign response and update the floor map.
}
